# ========================================
# CC Companion Kit 配置文件
# 复制这个文件为 .env，然后填入你自己的值
# ========================================

# --- 聊天服务器 (chat-server) ---
CHAT_PORT=4500                    # 聊天服务器端口，可以改成你喜欢的
CHAT_PASSWORD=your-secret-password # 网页聊天的登录密码

# --- 手机小组件 (phone-widget) ---
CLIENT_PORT=4600                  # 小组件前端端口
BRIDGE_PORT=4601                  # MCP Bridge 内部端口（给 Claude Code 连接用的）

# --- 域名（nginx 配置用） ---
DOMAIN=your-domain.com

# --- Bark 推送通知（可选，iOS 用户推荐） ---
# 从 Bark App 里获取你的 key
BARK_KEY_1=your-bark-key
BARK_KEY_2=your-second-device-bark-key   # 如果有第二台设备
BARK_ICON_URL=https://example.com/your-icon.png  # 通知图标
BARK_GROUP=companion              # 通知分组名

# --- Companion 身份信息 ---
COMPANION_NAME=Companion          # 你的 companion 的名字
COMPANION_AVATAR=C                # 头像显示的字母
