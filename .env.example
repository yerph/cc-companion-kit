# Chat Server
CHAT_PORT=3500
CHAT_PASSWORD=your-secret-password

# Phone Widget / CC Bridge
BRIDGE_PORT=3462

# Domain (for nginx config)
DOMAIN=your-domain.com

# Bark Push Notifications (optional)
# Get your key from the Bark iOS app
BARK_KEY_1=your-bark-key
BARK_KEY_2=your-second-device-bark-key

# Bark notification settings
BARK_ICON_URL=https://example.com/your-icon.png
BARK_GROUP=companion

# Companion identity (used in tweets/postcards)
COMPANION_NAME=Companion
COMPANION_AVATAR=C
